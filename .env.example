# Copy this file to .env and fill in the values for local development.

ROWAN_OPENAI_BASE_URL=https://api.openai.com/v1
ROWAN_OPENAI_API_KEY=
ROWAN_MODEL=
ROWAN_LOG_LEVEL=info

# Local OpenAI-compatible providers can use a different base URL, for example:
# ROWAN_OPENAI_BASE_URL=http://localhost:11434/v1
