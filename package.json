{
  "name": "rowan-agent",
  "version": "0.8.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "build:packages": "bun run --filter '@rowan-agent/*' build",
    "test": "bun test packages",
    "rowan": "bun packages/cli/src/cli.ts",
    "release": "bun run build:packages && bun run publish:packages",
    "publish:packages": "bun scripts/publish.ts"
  },
  "dependencies": {
    "typebox": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
